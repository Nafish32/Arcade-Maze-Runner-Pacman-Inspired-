{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Pac-Man",
            "type": "shell",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                ".\\project.cpp",
                "-std=c++17",
                "-g",
                "-o",
                ".\\project.exe",
                "-lfreeglut",
                "-lopengl32",
                "-lglu32"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "Path": "C:\\msys64\\ucrt64\\bin;${env:Path}"
                }
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Run Pac-Man",
            "type": "shell",
            "command": ".\\project.exe",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "Path": "C:\\msys64\\ucrt64\\bin;${env:Path}"
                }
            }
        },
        {
            "label": "Build and Run Pac-Man",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Pac-Man",
                "Run Pac-Man"
            ]
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build active file",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ]
}